# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration (SQLite)
DB_PATH=./smart_farming.db

# JWT Configuration
JWT_ACCESS_SECRET=your_access_secret_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_here_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# Cloud Storage (AWS S3 or Cloudinary)
CLOUD_STORAGE_PROVIDER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=Smart Farming 360 <noreply@smartfarming360.com>

# Payment Configuration
# Mobile Money
MTN_API_KEY=
MTN_API_SECRET=
VODAFONE_API_KEY=
VODAFONE_API_SECRET=
AIRTELTIGO_API_KEY=
AIRTELTIGO_API_SECRET=

# Payment Gateway (Paystack or Flutterwave)
PAYMENT_GATEWAY=paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5
